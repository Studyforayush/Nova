# Backend API base URL (leave empty to use relative /api with proxy in dev)
# Production build example: https://lms-mern-aaj1.onrender.com
VITE_API_BASE_URL=

# In dev, proxy /api targets this (default: http://localhost:5010)
# Set to https://lms-mern-aaj1.onrender.com to use production API during dev
# VITE_PROXY_TARGET=http://localhost:5010

# Firebase
VITE_FIREBASE_API_KEY=your_firebase_api_key

# Stripe (public key)
VITE_STRIPE_PUBLIC_KEY=your_stripe_public_key

# Cloudinary (upload)
VITE_CLOUDINARY_URL=your_cloudinary_upload_url
